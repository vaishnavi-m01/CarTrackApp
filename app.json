{
  "expo": {
    "name": "CarTrack Pro",
    "slug": "cartrack-pro",
    "scheme": "cartrack",
    "version": "1.0.0",
    "icon": "./src/assets/icon.png",
    "primaryColor": "#764ba2",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.vaishnavim21052004.cartrackpro",
      "versionCode": 2,
      "allowBackup": true,
      "icon": "./src/assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#764ba2"
      }
    },
    "extra": {
      "eas": {
        "projectId": "310c7ea6-23db-4d63-9f9b-8887f3afc783"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
